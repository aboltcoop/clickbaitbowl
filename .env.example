# Anthropic API key — powers the "Sync live scores" button (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — created automatically if you add the Upstash integration in Vercel.
# For local dev, copy the values from the Vercel dashboard (Storage -> your database -> .env.local tab)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: require a code before anyone can save score edits.
# Leave unset to allow open editing (fine for a friends pool).
ADMIN_CODE=
